  "components": {
    "schemas": {
      "BacktestResult": {
        "properties": {
          "window_months": {
            "type": "integer",
            "enum": [
              3,
              6,
              12
            ],
            "title": "Window Months",
            "default": 6
          },
          "rolling_accuracy_full": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rolling Accuracy Full"
          },
          "rolling_accuracy_partial": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rolling Accuracy Partial"
          },
          "estimated_return": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Estimated Return"
          },
          "benchmark": {
            "type": "string",
            "title": "Benchmark"
          },
          "insufficient_history": {
            "type": "boolean",
            "title": "Insufficient History",
            "default": true
          },
          "methodology_version": {
            "type": "string",
            "title": "Methodology Version"
          },
          "disclaimer": {
            "type": "string",
            "title": "Disclaimer",
            "default": "Personal decision-support only \u2014 not financial advice. Past performance does not guarantee future results."
          }
        },
        "type": "object",
        "required": [
          "benchmark",
          "methodology_version"
        ],
        "title": "BacktestResult"
      },
      "CompositeCall": {
        "type": "string",
        "enum": [
          "STRONG_SELL",
          "SELL",
          "HOLD",
          "BUY",
          "STRONG_BUY",
          "SUPPRESSED"
        ],
        "title": "CompositeCall"
      },
      "ConfidenceLevel": {
        "type": "string",
        "enum": [
          "HIGH",
          "MEDIUM",
          "LOW"
        ],
        "title": "ConfidenceLevel"
      },
      "Dashboard": {
        "properties": {
          "ticker": {
            "type": "string",
            "title": "Ticker"
          },
          "rec_date": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rec Date"
          },
          "recommendation": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Recommendation"
              },
              {
                "type": "null"
              }
            ]
          },
          "modules": {
            "$ref": "#/components/schemas/DashboardModules"
          },
          "supply_chain_available": {
            "type": "boolean",
            "title": "Supply Chain Available",
            "default": false
          },
          "disclaimer": {
            "type": "string",
            "title": "Disclaimer",
            "default": "Personal decision-support only \u2014 not financial advice. Past performance does not guarantee future results."
          }
        },
        "type": "object",
        "required": [
          "ticker",
          "rec_date",
          "recommendation",
          "modules"
        ],
        "title": "Dashboard"
      },
      "DashboardModules": {
        "properties": {
          "technical": {
            "$ref": "#/components/schemas/ModuleSummary"
          },
          "fundamental": {
            "$ref": "#/components/schemas/ModuleSummary"
          },
          "chip": {
            "$ref": "#/components/schemas/ModuleSummary"
          },
          "news": {
            "$ref": "#/components/schemas/ModuleSummary"
          }
        },
        "type": "object",
        "required": [
          "technical",
          "fundamental",
          "chip",
          "news"
        ],
        "title": "DashboardModules"
      },
      "DecisionAnnotation": {
        "properties": {
          "decision": {
            "type": "string",
            "enum": [
              "followed",
              "ignored",
              "partial"
            ],
            "title": "Decision"
          },
          "transaction_price": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transaction Price"
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "decision"
        ],
        "title": "DecisionAnnotation"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "username": {
            "type": "string",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "title": "Password"
          },
          "client": {
            "type": "string",
            "enum": [
              "web",
              "ios"
            ],
            "title": "Client"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password",
          "client"
        ],
        "title": "LoginRequest"
      },
      "ModuleDetail": {
        "properties": {
          "module": {
            "type": "string",
            "title": "Module"
          },
          "status": {
            "$ref": "#/components/schemas/ModuleStatus"
          },
          "signal_score": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 2.0,
                "minimum": -2.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Signal Score"
          },
          "as_of": {
            "anyOf": [
              {
                "type": "string",
                "format": "date"
              },
              {
                "type": "null"
              }
            ],
            "title": "As Of"
          },
          "series": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Series",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "module",
          "status"
        ],
        "title": "ModuleDetail",
        "description": "Base lens-detail envelope (contract v1.2.1); per-lens extended fields\n(TechnicalDetail latest/series, FundamentalDetail ratios, ...) are filled\nby the ingestion steps (tasks #8/#9/#12)."
      },
      "ModuleStatus": {
        "type": "string",
        "enum": [
          "ok",
          "unavailable"
        ],
        "title": "ModuleStatus"
      },
      "ModuleSummary": {
        "properties": {
          "status": {
            "$ref": "#/components/schemas/ModuleStatus"
          },
          "signal_score": {
            "anyOf": [
              {
                "type": "number",
                "maximum": 2.0,
                "minimum": -2.0
              },
              {
                "type": "null"
              }
            ],
            "title": "Signal Score"
          },
          "headline_metric": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Headline Metric"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "ModuleSummary"
      },
      "ModuleWeights": {
        "properties": {
          "technical": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Technical",
            "default": 0.3
          },
          "fundamental": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Fundamental",
            "default": 0.3
          },
          "chip": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Chip",
            "default": 0.25
          },
          "news": {
            "type": "number",
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "News",
            "default": 0.15
          }
        },
        "type": "object",
        "title": "ModuleWeights"
      },
      "PerModuleBreakdown": {
        "properties": {
          "module": {
            "type": "string",
            "enum": [
              "technical",
              "fundamental",
              "chip",
