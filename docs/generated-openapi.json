    "/api/v1/stocks/{ticker}/backtest": {
      "get": {
        "tags": [
          "stocks"
        ],
        "summary": "Backtest",
        "description": "Backtest engine lands in Step 7 (task #13); until >=12mo of history is\nbackfilled this honestly reports insufficient_history=true (nfr-budgets.md).",
        "operationId": "backtest_api_v1_stocks__ticker__backtest_get",
        "parameters": [
          {
            "name": "ticker",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ticker"
            }
          },
          {
            "name": "window_months",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [
                3,
                6,
                12
              ],
              "default": 6,
              "title": "Window Months"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BacktestResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/recommendations/log": {
      "get": {
        "tags": [
          "recommendations"
        ],
        "summary": "Recommendation Log",
        "description": "Immutable recommendation history with any user annotations.",
        "operationId": "recommendation_log_api_v1_recommendations_log_get",
        "parameters": [
          {
            "name": "ticker",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Ticker"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 365,
              "default": 30,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RecommendationLogEntry"
                  },
                  "title": "Response Recommendation Log Api V1 Recommendations Log Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/recommendations/log/{rec_date}/annotate": {
      "post": {
        "tags": [
          "recommendations"
        ],
        "summary": "Annotate",
        "description": "Records what the user did. Annotates the immutable recommendation row \u2014\nnever mutates it. Price/notes are personal financial data: encrypted\ncolumn-level via pgcrypto before hitting disk (NFR-05).",
        "operationId": "annotate_api_v1_recommendations_log__rec_date__annotate_post",
        "parameters": [
          {
            "name": "rec_date",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date",
              "title": "Rec Date"
            }
          },
          {
            "name": "ticker",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Ticker"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DecisionAnnotation"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Annotate Api V1 Recommendations Log  Rec Date  Annotate Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
