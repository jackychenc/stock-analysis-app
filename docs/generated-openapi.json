              }
            }
          }
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login",
        "description": "One verifier, two strategies: web gets a session cookie (empty bundle);\niOS gets JWT access + refresh tokens. [ADR-002]",
