{
  "_meta": {
    "title": "Golden Fixtures — Recommendation Engine (D1) + Backtest (D5)",
    "owner": "A6 SDLCQATestEngineerAgent",
    "binds_to": "A3 domain-contract v1.2.1 (§1-§10), schema.sql v1.1, A2 Requirements v0.2",
    "purpose": "Machine-usable expected input->output cases. A5 binds task #10 engine to these; A6 asserts them. Any divergence = defect (Cindy ruling 2026-07-08), not an open OQ.",
    "conventions": {
      "default_weights": {"technical": 0.30, "fundamental": 0.30, "chip": 0.25, "news": 0.15},
      "composite_round": "half-up to 2 decimals (NUMERIC(4,2))",
      "weight_effective_round": "2 decimals",
      "target_round": "4 decimals",
      "bands": "STRONG_SELL[-2,-1.5) SELL[-1.5,-0.75) HOLD[-0.75,+0.75] BUY(+0.75,+1.5] STRONG_BUY(+1.5,+2.0]; boundary->milder",
      "conflict": "spread=max-min over available signals; flag when spread>2.0 (strict)",
      "confidence": "HOLD-call: agree=count(|signal|<=0.75); else: agree=count(sign(signal)==sign(composite)), signal==0 does not agree. pct=100*agree/n_available. HIGH>=75 MEDIUM[50,75) LOW<50",
      "target": "usable = fundamental_scoring_available AND trailing_EPS>0 AND peer_median_PE is not null. usable-> base=0.5*(PE*EPS)+0.5*close ; else base=close + reduced_confidence framing. bear=base*0.85 bull=base*1.15"
    }
  },

  "D1_scoring": [
    {
      "id": "GF-A-normal",
      "desc": "State A: all 4 ok, Buy, no conflict, High confidence",
      "input": {"signals": {"technical": 1.2, "fundamental": 0.8, "chip": 1.5, "news": -0.5},
                "available": ["technical","fundamental","chip","news"],
                "target_inputs": {"peer_median_PE": 18.0, "trailing_EPS": 40.0, "latest_close": 900.0}},
      "expect": {"composite_signal": 0.90, "composite_call": "BUY",
                 "weight_effective": {"technical": 0.30, "fundamental": 0.30, "chip": 0.25, "news": 0.15},
                 "data_completeness": 1.00, "reduced_confidence": false,
                 "spread": 2.0, "conflict_flag": false,
                 "confidence_pct": 75.00, "confidence_level": "HIGH",
                 "target_base": 810.0000, "target_bear": 688.5000, "target_bull": 931.5000,
                 "target_fundamental_usable": true}
    },
    {
      "id": "GF-B-reduced-technical-down",
      "desc": "State B: technical unavailable -> renormalise over 3, Reduced Confidence, Buy just above Hold edge",
      "input": {"signals": {"fundamental": 0.8, "chip": 1.5, "news": -0.5},
                "available": ["fundamental","chip","news"],
                "target_inputs": {"peer_median_PE": 18.0, "trailing_EPS": 40.0, "latest_close": 900.0}},
      "expect": {"composite_signal": 0.77, "composite_call": "BUY",
                 "weight_effective": {"technical": 0.00, "fundamental": 0.43, "chip": 0.36, "news": 0.21},
                 "data_completeness": 0.75, "reduced_confidence": true,
                 "spread": 2.0, "conflict_flag": false,
                 "confidence_pct": 66.67, "confidence_level": "MEDIUM",
                 "target_base": 810.0000, "target_bear": 688.5000, "target_bull": 931.5000,
                 "target_fundamental_usable": true,
                 "note": "composite raw 0.540/0.70=0.771428 -> 0.77; band on persisted 2dp value; still BUY (>+0.75)"}
    },
    {
      "id": "GF-C-suppressed-two-down",
      "desc": "State C: technical+chip unavailable (>=2) -> SUPPRESS, no score/target/confidence",
      "input": {"signals": {"fundamental": 0.8, "news": -0.5},
                "available": ["fundamental","news"]},
      "expect": {"composite_signal": null, "composite_call": "SUPPRESSED",
                 "suppressed_reason": "Analysis Only — Insufficient Data",
                 "target_base": null, "target_bear": null, "target_bull": null,
                 "confidence_pct": null, "data_completeness": 0.50,
                 "per_module_breakdown_len": 4,
                 "note": "DB ck_rec_suppressed_shape must accept this row; breakdown still lists all 4 with statuses"}
    },
    {
      "id": "GF-D-conflict-hold-low",
      "desc": "State D: all ok but strong disagreement -> Hold, conflict flag, LOW confidence (Hold-consistent=0)",
      "input": {"signals": {"technical": 1.9, "fundamental": -1.5, "chip": 1.7, "news": -0.8},
                "available": ["technical","fundamental","chip","news"],
                "target_inputs": {"peer_median_PE": 15.0, "trailing_EPS": 30.0, "latest_close": 500.0}},
      "expect": {"composite_signal": 0.43, "composite_call": "HOLD",
                 "data_completeness": 1.00, "reduced_confidence": false,
                 "spread": 3.4, "conflict_flag": true,
                 "confidence_pct": 0.00, "confidence_level": "LOW",
                 "target_base": 475.0000, "target_bear": 403.7500, "target_bull": 546.2500,
                 "target_fundamental_usable": true,
                 "note": "composite raw 0.425 -> half-up 0.43; HOLD so confidence = count(|signal|<=0.75)=0/4"}
    },

    {"id": "GF-BAND-SS", "desc": "band: below -1.5 -> Strong Sell", "input": {"composite_signal": -1.51}, "expect": {"composite_call": "STRONG_SELL"}},
    {"id": "GF-BAND-SS-edge", "desc": "band: exactly -1.5 -> milder -> Sell", "input": {"composite_signal": -1.50}, "expect": {"composite_call": "SELL"}},
    {"id": "GF-BAND-S-hold-edge", "desc": "band: exactly -0.75 -> milder -> Hold", "input": {"composite_signal": -0.75}, "expect": {"composite_call": "HOLD"}},
    {"id": "GF-BAND-hold-zero", "desc": "band: 0 -> Hold", "input": {"composite_signal": 0.00}, "expect": {"composite_call": "HOLD"}},
    {"id": "GF-BAND-hold-buy-edge", "desc": "band: exactly +0.75 -> milder -> Hold", "input": {"composite_signal": 0.75}, "expect": {"composite_call": "HOLD"}},
    {"id": "GF-BAND-buy-sb-edge", "desc": "band: exactly +1.5 -> milder -> Buy", "input": {"composite_signal": 1.50}, "expect": {"composite_call": "BUY"}},
    {"id": "GF-BAND-SB", "desc": "band: above +1.5 -> Strong Buy", "input": {"composite_signal": 1.51}, "expect": {"composite_call": "STRONG_BUY"}},

    {"id": "GF-CONF-hold-zero-agrees", "desc": "confidence: in HOLD, signal 0 and small signals are Hold-consistent",
     "input": {"composite_call": "HOLD", "available_signals": [0.0, 0.5, 0.7, -0.6]}, "expect": {"confidence_pct": 100.00, "confidence_level": "HIGH"}},
    {"id": "GF-CONF-buy-zero-no-agree", "desc": "confidence: in BUY, signal 0 does NOT agree",
     "input": {"composite_call": "BUY", "composite_sign": 1, "available_signals": [1.2, 0.0, 0.9, -0.5]}, "expect": {"confidence_pct": 50.00, "confidence_level": "MEDIUM"}},
    {"id": "GF-CONF-composite-zero", "desc": "confidence: composite exactly 0 -> HOLD -> |signal|<=0.75 count",
     "input": {"composite_signal": 0.00, "composite_call": "HOLD", "available_signals": [0.0, 0.6, -0.7, 1.9]}, "expect": {"confidence_pct": 75.00, "confidence_level": "HIGH"}},

    {"id": "GF-TGT-negeps", "desc": "target: trailing_EPS<=0 -> technical-only (close) + reduced confidence framing (v1.2.1 guard)",
     "input": {"peer_median_PE": 18.0, "trailing_EPS": -5.0, "latest_close": 900.0, "fundamental_scoring_available": true},
     "expect": {"target_fundamental_usable": false, "target_base": 900.0000, "target_bear": 765.0000, "target_bull": 1035.0000, "reduced_confidence_framing": true}},
    {"id": "GF-TGT-nope", "desc": "target: peer_median_PE null -> technical-only (close)",
     "input": {"peer_median_PE": null, "trailing_EPS": 40.0, "latest_close": 900.0, "fundamental_scoring_available": true},
     "expect": {"target_fundamental_usable": false, "target_base": 900.0000, "target_bear": 765.0000, "target_bull": 1035.0000, "reduced_confidence_framing": true}},
    {"id": "GF-TGT-funddown", "desc": "target: fundamental scoring module unavailable -> technical-only (close) + reduced confidence (renormalisation)",
     "input": {"latest_close": 900.0, "fundamental_scoring_available": false},
     "expect": {"target_fundamental_usable": false, "target_base": 900.0000, "reduced_confidence": true}}
  ],

  "D5_backtest": [
    {"id": "GF-BT-buy-correct", "desc": "Buy correct if stock beats benchmark by >2pp",
     "input": {"call": "BUY", "stock_return_pct": 8.0, "benchmark_return_pct": 5.0}, "expect": {"delta_pp": 3.0, "correct": true}},
    {"id": "GF-BT-buy-edge", "desc": "Buy at exactly +2pp -> NOT correct (strict >)",
     "input": {"call": "BUY", "stock_return_pct": 7.0, "benchmark_return_pct": 5.0}, "expect": {"delta_pp": 2.0, "correct": false}},
    {"id": "GF-BT-sell-correct", "desc": "Sell correct if it lags benchmark by >2pp (delta < -2)",
     "input": {"call": "SELL", "stock_return_pct": 1.0, "benchmark_return_pct": 5.0}, "expect": {"delta_pp": -4.0, "correct": true}},
    {"id": "GF-BT-hold-excluded", "desc": "Hold excluded from accuracy entirely",
     "input": {"call": "HOLD", "stock_return_pct": 9.0, "benchmark_return_pct": 5.0}, "expect": {"counted_in_accuracy": false}},
    {"id": "GF-BT-partial-segregated", "desc": "partial-data day never blends into headline",
     "input": {"day_type": "partial"}, "expect": {"in_rolling_accuracy_full": false, "in_rolling_accuracy_partial": true}},
    {"id": "GF-BT-insufficient-history", "desc": "<12 months history -> insufficient_history, no headline number",
     "input": {"history_months": 8}, "expect": {"insufficient_history": true, "rolling_accuracy_full": null}},
    {"id": "GF-BT-benchmark-by-market", "desc": "benchmark matched to ticker market",
     "input": {"markets": {"2330.TW": "^TWII", "AAPL": "^GSPC"}}, "expect": {"2330.TW": "^TWII", "AAPL": "^GSPC"}}
  ]
}
